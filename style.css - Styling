* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
    padding: 20px;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
}

h1 {
    text-align: center;
    color: #333;
    margin-bottom: 30px;
    font-size: 2.5em;
}

.search-section {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 30px;
}

#atomic-number {
    padding: 12px 20px;
    font-size: 16px;
    border: 2px solid #667eea;
    border-radius: 5px;
    width: 300px;
    transition: border-color 0.3s;
}

#atomic-number:focus {
    outline: none;
    border-color: #764ba2;
}

#search-btn {
    padding: 12px 30px;
    font-size: 16px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: transform 0.2s;
    font-weight: bold;
}

#search-btn:hover {
    transform: scale(1.05);
}

.element-info {
    background: #f8f9fa;
    border-left: 5px solid #667eea;
    padding: 20px;
    margin-bottom: 30px;
    border-radius: 5px;
    display: none;
}

.element-info.hidden {
    display: none;
}

.element-info.show {
    display: block;
    animation: slideIn 0.3s ease-in;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

#element-name {
    color: #667eea;
    margin-bottom: 15px;
}

.info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}

.info-grid div {
    background: white;
    padding: 10px 15px;
    border-radius: 5px;
    border: 1px solid #ddd;
}

.periodic-table {
    display: grid;
    grid-template-columns: repeat(18, 1fr);
    gap: 8px;
    margin-top: 30px;
}

.element {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border: 2px solid #333;
    border-radius: 5px;
    cursor: pointer;
    font-size: 12px;
    font-weight: bold;
    transition: all 0.3s;
    padding: 8px;
    text-align: center;
    user-select: none;
}

.element:hover {
    transform: scale(1.05);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
}

.element.highlight {
    background: #FFD700 !important;
    border-color: #FFA500;
    box-shadow: 0 0 20px rgba(255, 215, 0, 0.8);
    transform: scale(1.1);
}

/* Element Categories */
.element.metal {
    background: #FFB347;
    color: #333;
}

.element.nonmetal {
    background: #90EE90;
    color: #333;
}

.element.halogen {
    background: #FFE4E1;
    color: #333;
}

.element.noble-gas {
    background: #ADD8E6;
    color: #333;
}

.element.transition-metal {
    background: #DDA0DD;
    color: #333;
}

.element.lanthanide {
    background: #F0E68C;
    color: #333;
}

.element.actinide {
    background: #FF6347;
    color: white;
}

.element-symbol {
    font-size: 1.2em;
    font-weight: bold;
}

.element-name {
    font-size: 0.8em;
}

.element-atomic {
    font-size: 0.8em;
    opacity: 0.7;
}

@media (max-width: 768px) {
    .periodic-table {
        grid-template-columns: repeat(10, 1fr);
        gap: 5px;
    }

    .element {
        font-size: 10px;
        padding: 5px;
    }

    h1 {
        font-size: 1.8em;
    }

    .search-section {
        flex-direction: column;
    }

    #atomic-number {
        width: 100%;
    }
}
